# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# D-ID
DID_API_KEY=
DID_BASE_URL=https://api.d-id.com
# Example: https://create.d-id.com/photos/<id>/image.jpeg or any publicly accessible URL
DID_SOURCE_IMAGE_URL=
# Example voice id; configure based on your D-ID account/plan
DID_VOICE_ID=en-US-JennyNeural

# Instagram (Meta Graph API)
IG_ACCESS_TOKEN=
IG_USER_ID=

# TikTok (Content Posting API)
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# Behavior & Scheduling
REQUESTS_PER_MINUTE=50
MIN_JITTER_SECONDS=0.6
MAX_JITTER_SECONDS=2.2
HTTP_TIMEOUT_SECONDS=45

# Output
OUTPUT_DIR=output
